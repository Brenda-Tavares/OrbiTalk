{
  "name": "@orbitalk/api",
  "version": "1.0.0",
  "description": "Backend API for OrbiTalk",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "npm install && npx prisma generate",
    "start": "node -r tsx ./src/app.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.5.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@fastify/websocket": "^10.0.0",
    "@prisma/client": "^5.8.0",
    "argon2": "^0.31.0",
    "dotenv": "^16.3.0",
    "fastify": "^4.25.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.0",
    "tsx": "^4.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.0",
    "eslint": "^8.56.0",
    "prisma": "^5.8.0",
    "typescript": "^5.3.0"
  }
}
